{
	"compatibility_date": "2026-05-28",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "exp3-prod",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "EXP3DB",
			"database_name": "exp3",
			"database_id": "8c2ee32b-653f-4f44-9f8f-c5f0808af683"
		}
	]
}