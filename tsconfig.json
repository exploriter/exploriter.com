{
   "extends": "astro/tsconfigs/strict",
   "include": [".astro/types.d.ts", "**/*", "./worker-configuration.d.ts"],
   "exclude": ["dist", "node_modules", "build"],
   "compilerOptions": {
      "jsx": "react-jsx",
      "jsxImportSource": "react",
      "paths": {
         "@/*": ["./src/*"]
      },
      "plugins": [
         {
            "name": "@astrojs/ts-plugin"
         }
      ]
   },
   "skipLibCheck": true
}
