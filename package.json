{
   "name": "exploriter",
   "type": "module",
   "version": "0.0.1",
   "engines": {
      "node": ">=22.12.0"
   },
   "scripts": {
      "dev": "astro dev",
      "build": "astro build",
      "preview": "astro preview",
      "astro": "astro",
      "generate-types": "wrangler types"
   },
   "dependencies": {
      "@astrojs/cloudflare": "^14.0.1",
      "@astrojs/mdx": "^7.0.0",
      "@astrojs/react": "^6.0.0",
      "@base-ui/react": "^1.6.0",
      "@phosphor-icons/react": "^2.1.10",
      "@tailwindcss/vite": "^4.3.1",
      "@tanstack/react-table": "^8.21.3",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "astro": "^7.0.3",
      "class-variance-authority": "^0.7.1",
      "clsx": "^2.1.1",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "shadcn": "^4.12.0",
      "tailwind-merge": "^3.6.0",
      "tailwindcss": "^4.3.1",
      "tw-animate-css": "^1.4.0",
      "wrangler": "^4.105.0"
   },
   "devDependencies": {
      "@astrojs/check": "^0.9.9",
      "@astrojs/ts-plugin": "^1.10.9",
      "prettier": "3.9.3",
      "prettier-plugin-astro": "0.14.1",
      "typescript": "^6.0.3"
   },
   "prettier": {
      "plugins": [
         "prettier-plugin-astro"
      ],
      "overrides": [
         {
            "files": "*.astro",
            "options": {
               "parser": "astro"
            }
         }
      ],
      "semi": true,
      "singleQuote": false,
      "tabWidth": 3,
      "trailingComma": "es5",
      "printWidth": 150
   },
   "overrides": {
      "vite": "^7"
   }
}
