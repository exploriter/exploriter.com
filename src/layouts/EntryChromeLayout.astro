---
import BreadcrumbTrail from "@/components/BreadcrumbTrail.astro";
import NotFoundPage from "@/components/NotFoundPage.astro";
import ProjectHereIcon from "@/components/ProjectHereIcon";
import SectionIcon, { ConceptKindIcon } from "@/components/icons/section-icon";
import { buttonVariants } from "@/components/ui/button";
import { cn } from "@/lib/css";
import { getEntryPageBySlugs, listFormationIntersectionSummaries } from "@/lib/exp3";
import HeaderLayout from "@/layouts/HeaderLayout.astro";
import { ArrowUpRightIcon } from "@phosphor-icons/react";

interface Props {
   containerClass?: string;
   showEntryHeader?: boolean;
}

const { containerClass, showEntryHeader = false } = Astro.props;
const [slugSingular, entrySlug] = Astro.url.pathname.split("/").filter(Boolean);

const entry = slugSingular && entrySlug ? await getEntryPageBySlugs(slugSingular, entrySlug) : null;

if (!entry) {
   Astro.response.status = 404;
}

const section = entry?.formationIntersection;
const isSiteProjectPage = slugSingular === "project" && entrySlug === "exploriter";
const sections = entry ? await listFormationIntersectionSummaries() : [];
const sectionSwitcher = {
   label: "Select section",
   options: [{ label: "All Entries", href: "/all" }, ...sections.map((section) => ({ label: section.name, href: `/${section.slug}` }))],
   value: `/${section?.slug ?? ""}`,
};
---

<HeaderLayout
   title={entry ? `${entry.title} — Exploriter` : "Page Not Found — Exploriter"}
   description={entry?.description ?? "The requested page could not be found."}
>
   {
      entry && section ? (
         <article class={cn("mx-auto max-w-4xl px-4 pb-20", containerClass)}>
            <BreadcrumbTrail items={[{ label: section.name, href: `/${section.slug}`, sectionSwitcher }, { label: entry.title }]}>
               {slugSingular === "concept" ? (
                  <ConceptKindIcon conceptKind={entry.conceptKind ?? "INDIVIDUAL"} className="size-4" client:only="react" />
               ) : (
                  <SectionIcon slug={section.slug} label={section.nameSingular} className="size-4" client:only="react" />
               )}
            </BreadcrumbTrail>

            {showEntryHeader ? (
               <header class="my-10 pb-10 border-b border-border">
                  <div class="flex max-w-4xl flex-col gap-4 sm:flex-row sm:items-center">
                     <h1 class="-ml-0.5 flex-1 font-serif text-5xl leading-tight">{entry.title}</h1>
                     {isSiteProjectPage ? (
                        <ProjectHereIcon className="sm:ml-auto" client:only="react" />
                     ) : entry.projectLink ? (
                        <a
                           class={cn(buttonVariants({ variant: "outline", size: "default" }), "sm:ml-auto")}
                           href={entry.projectLink}
                           rel="noreferrer"
                           target="_blank"
                        >
                           Visit
                           <ArrowUpRightIcon className="size-3.5" aria-hidden="true" />
                        </a>
                     ) : null}
                  </div>
                  {entry.description ? <p class="mt-5 max-w-3xl font-serif text-xl leading-8 text-muted-foreground">{entry.description}</p> : null}
               </header>
            ) : null}

            <slot />
         </article>
      ) : (
         <NotFoundPage path={Astro.url.pathname} />
      )
   }
</HeaderLayout>
