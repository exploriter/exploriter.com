---
const { path = "/" } = Astro.props;
---

<section class="mx-auto max-w-4xl px-5 pb-20">
   <p class="font-mono text-xs uppercase tracking-wider text-muted-foreground">404</p>
   <h1 class="mt-4 font-serif text-5xl font-medium leading-tight sm:text-6xl">Page not found.</h1>
   <p class="mt-5 max-w-2xl text-base leading-7 text-muted-foreground">
      The page at <span class="font-mono text-foreground">{path}</span> does not exist in the public knowledge base.
   </p>
   <a href="/" class="mt-8 inline-flex border border-border px-4 py-2 text-sm transition hover:bg-muted">Return home</a>
</section>
