---
export const prerender = false;

import HeaderLayout from "@/layouts/HeaderLayout.astro";
import { env } from "cloudflare:workers";

const counts = await Promise.all(
   [
      "analogs",
      "exp3s",
      "vertical_dimensions",
      "horizontal_dimensions",
      "formation_intersections",
      "description_variants",
      "entries",
   ].map(async (table) => {
      const row = await env.EXP3DB.prepare(`SELECT COUNT(*) AS count FROM ${table}`).first<{ count: number }>();
      return { table, count: row?.count ?? 0 };
   })
);
---

<HeaderLayout title="D1 Debug" description="Temporary D1 binding check.">
   <section class="mx-auto max-w-3xl px-6 py-16">
      <h1 class="font-serif text-4xl font-medium">D1 Debug</h1>
      <p class="mt-3 text-sm text-neutral-600">Temporary read-only check for the EXP3 D1 binding.</p>

      <dl class="mt-8 divide-y divide-neutral-200 border-y border-neutral-200">
         {
            counts.map(({ table, count }) => (
               <div class="grid grid-cols-[1fr_auto] gap-4 py-3">
                  <dt class="font-mono text-sm text-neutral-700">{table}</dt>
                  <dd class="font-mono text-sm font-medium">{count}</dd>
               </div>
            ))
         }
      </dl>
   </section>
</HeaderLayout>
