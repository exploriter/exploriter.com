---
import EntryChromeLayout from "@/layouts/EntryChromeLayout.astro";
import { loadEntryContent } from "@/lib/entry-content";

const { slugSingular, entrySlug } = Astro.params;

const EntryContent = slugSingular && entrySlug ? await loadEntryContent(slugSingular, entrySlug) : null;
---

<EntryChromeLayout showEntryHeader>
   {EntryContent ? (
      <div class="entry-prose">
         <EntryContent />
      </div>
   ) : (
      <section class="entry-prose">
         <p class="text-sm border border-notice/33 bg-notice/5 px-4 py-3 rounded text-notice">
            This entry exists in the <code>EXP3</code> database. A full page is pending migration/publication. Check back soon!
         </p>
      </section>
   )}
</EntryChromeLayout>
