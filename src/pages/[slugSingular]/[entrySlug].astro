---
import HeaderLayout from "@/layouts/HeaderLayout.astro";
import NotFoundPage from "@/components/NotFoundPage.astro";
import { loadEntryContent } from "@/lib/entry-content";
import { getEntryPageBySlugs } from "@/lib/exp3";

export const prerender = false;

const { slugSingular, entrySlug } = Astro.params;

const entry = slugSingular && entrySlug ? await getEntryPageBySlugs(slugSingular, entrySlug) : null;

if (!entry) {
   Astro.response.status = 404;
}

const section = entry?.formationIntersection;
const EntryContent = entry && slugSingular && entrySlug ? await loadEntryContent(slugSingular, entrySlug) : null;
---

<HeaderLayout
   title={entry ? `${entry.title} — Exploriter` : "Page Not Found — Exploriter"}
   description={entry?.description ?? "The requested page could not be found."}
>
   {
      entry && section ? (
         <article class="mx-auto max-w-4xl px-5 pb-20">
            <nav aria-label="Breadcrumb" class="flex flex-wrap items-center gap-2 font-mono text-xs uppercase text-muted-foreground">
               <a href="/" class="hover:text-foreground hover:underline hover:underline-offset-4">
                  EXP3
               </a>
               <span>/</span>
               <a href={`/${section.slug}`} class="hover:text-foreground hover:underline hover:underline-offset-4">
                  {section.name}
               </a>
            </nav>

            <header class="mt-10 max-w-3xl">
               <p class="font-mono text-xs uppercase tracking-wider text-muted-foreground">
                  /{section.slugSingular}/{entry.slug}
               </p>
               <h1 class="mt-4 -ml-0.75 font-serif text-5xl leading-tight sm:text-6xl">{entry.title}</h1>
               <p class="mt-5 font-serif text-xl leading-8 text-muted-foreground">{entry.description}</p>
            </header>

            {EntryContent ? (
               <div class="entry-prose mt-14 max-w-none">
                  <EntryContent />
               </div>
            ) : (
               <section class="mt-14 border-y border-border py-10">
                  <p class="font-mono text-xs uppercase tracking-wider text-muted-foreground">Coming Soon</p>
                  <p class="mt-3 max-w-2xl text-sm leading-6 text-muted-foreground">
                     This entry exists in the EXP3 database. A full page has not been published yet.
                  </p>
               </section>
            )}
         </article>
      ) : (
         <NotFoundPage path={Astro.url.pathname} />
      )
   }
</HeaderLayout>
