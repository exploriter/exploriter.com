---
import BreadcrumbTrail from "@/components/BreadcrumbTrail.astro";
import { ConceptKindIcon } from "@/components/icons/section-icon";
import SectionIcon from "@/components/icons/section-icon";
import HeaderLayout from "@/layouts/HeaderLayout.astro";
import { listAllEntrySummaries } from "@/lib/exp3";

export const prerender = false;

const entries = await listAllEntrySummaries();
---

<HeaderLayout title="All Entries — Exploriter" description="All EXP3 knowledge base entries listed alphabetically.">
   <section class="mx-auto max-w-6xl px-4 pb-20">
      <BreadcrumbTrail items={[{ label: "All Entries" }]} />

      <div class="mt-8">
         <h1 class="min-w-0 shrink-0 -ml-0.5 font-serif text-5xl leading-tight">All Entries</h1>
         <p class="mt-5 text-base leading-7 text-muted-foreground">
            Every published <code>EXP3</code> entry, listed alphabetically across all nine formation intersections.
         </p>
      </div>

      <section class="mt-12">
         <div class="flex items-end justify-between gap-4 border-b border-border pb-3">
            <h2 class="font-mono text-xs uppercase text-muted-foreground">Entries</h2>
            <p class="font-mono text-xs uppercase text-muted-foreground">{entries.length} total</p>
         </div>

         {
            entries.length > 0 ? (
               <ul class="divide-y divide-border">
                  {entries.map((entry) => {
                     const section = entry.formationIntersection;
                     return (
                        <li>
                           <a
                              href={`/${section.slugSingular}/${entry.slug}`}
                              class="group -mx-3 block rounded-md px-3 py-5 transition hover:bg-muted/50 sm:-mx-4 sm:px-4"
                           >
                              <div class="flex items-center">
                                 {section.slugSingular === "concept" && entry.conceptKind ? (
                                    <ConceptKindIcon
                                       className="mr-2 hidden size-5 sm:block"
                                       conceptKind={entry.conceptKind}
                                       weight="regular"
                                       client:only="react"
                                    />
                                 ) : (
                                    <SectionIcon
                                       slug={section.slug}
                                       label={section.nameSingular}
                                       className="mr-2 hidden size-5 sm:block"
                                       client:only="react"
                                    />
                                 )}
                                 <h3 class="font-serif text-xl group-hover:underline group-hover:decoration-1 group-hover:underline-offset-2">
                                    {entry.title}
                                 </h3>
                              </div>
                              {entry.description ? <p class="mt-2 max-w-3xl text-sm leading-6 text-muted-foreground">{entry.description}</p> : null}
                           </a>
                        </li>
                     );
                  })}
               </ul>
            ) : (
               <p class="py-6 text-sm leading-6 text-muted-foreground">No entries have been published yet.</p>
            )
         }
      </section>
   </section>
</HeaderLayout>
