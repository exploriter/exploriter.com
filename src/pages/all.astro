---
import BreadcrumbTrail from "@/components/BreadcrumbTrail.astro";
import { ConceptKindIcon } from "@/components/icons/section-icon";
import SectionIcon from "@/components/icons/section-icon";
import HeaderLayout from "@/layouts/HeaderLayout.astro";
import { listAllEntrySummaries } from "@/lib/exp3";

export const prerender = false;

const entries = await listAllEntrySummaries();
---

<HeaderLayout title="All Entries — Exploriter" description="All EXP3 knowledge base entries listed alphabetically.">
   <section class="mx-auto max-w-5xl px-5 pb-20">
      <BreadcrumbTrail items={[{ label: "All Entries" }]} />

      <div class="mt-8 max-w-3xl">
         <h1 class="-ml-0.75 font-serif text-5xl font-medium leading-tight sm:text-6xl">All Entries</h1>
         <p class="mt-5 text-base leading-7 text-muted-foreground">
            Every published EXP3 entry, listed alphabetically across all nine formation intersections.
         </p>
      </div>

      <section class="mt-12">
         <div class="flex items-end justify-between gap-4 border-b border-border pb-3">
            <h2 class="font-serif text-2xl font-medium">Entries</h2>
            <p class="font-mono text-xs uppercase text-muted-foreground">{entries.length} total</p>
         </div>

         {
            entries.length > 0 ? (
               <ul class="divide-y divide-border">
                  {entries.map((entry) => {
                     const section = entry.formationIntersection;
                     return (
                        <li>
                           <a href={`/${section.slugSingular}/${entry.slug}`} class="group block py-5 transition hover:bg-muted/50">
                              <div class="flex items-center gap-2">
                                 {section.slugSingular === "concept" && entry.conceptKind ? (
                                    <ConceptKindIcon conceptKind={entry.conceptKind} client:only="react" />
                                 ) : (
                                    <SectionIcon slug={section.slug} label={section.nameSingular} client:only="react" />
                                 )}
                                 <h3 class="font-serif text-2xl font-medium">{entry.title}</h3>
                              </div>
                              <p class="mt-2 max-w-3xl text-sm leading-6 text-muted-foreground">{entry.description}</p>
                           </a>
                        </li>
                     );
                  })}
               </ul>
            ) : (
               <p class="py-6 text-sm leading-6 text-muted-foreground">No entries have been published yet.</p>
            )
         }
      </section>
   </section>
</HeaderLayout>
