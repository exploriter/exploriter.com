---
import HeaderLayout from "@/layouts/HeaderLayout.astro";
import NotFoundPage from "@/components/NotFoundPage.astro";
import { ConceptKindIcon } from "@/components/icons/section-icon";
import { getFormationIntersectionSummaryBySlug, listEntrySummariesByFormationIntersectionSlug } from "@/lib/exp3";

export const prerender = false;

const { slug } = Astro.params;

const section = slug ? await getFormationIntersectionSummaryBySlug(slug) : null;

if (!section) {
   Astro.response.status = 404;
}

const entries = slug && section ? await listEntrySummariesByFormationIntersectionSlug(slug) : [];
---

<HeaderLayout
   title={section ? `${section.name} — Exploriter` : "Page Not Found — Exploriter"}
   description={section?.description ?? "The requested page could not be found."}
>
   {
      section ? (
         <section class="mx-auto max-w-5xl px-5 pb-20">
            <a href="/" class="font-mono text-xs uppercase text-muted-foreground hover:text-foreground hover:underline hover:underline-offset-4">
               EXP3
            </a>

            <div class="mt-8 max-w-3xl">
               <p class="font-mono text-xs uppercase tracking-wider text-muted-foreground">/{section.slug}</p>
               <h1 class="mt-4 -ml-0.75 font-serif text-5xl font-medium leading-tight sm:text-6xl">{section.name}</h1>
               <p class="mt-5 text-base leading-7 text-muted-foreground">{section.description}</p>
            </div>

            <section class="mt-12">
               <div class="flex items-end justify-between gap-4 border-b border-border pb-3">
                  <h2 class="font-serif text-2xl font-medium">Entries</h2>
                  <p class="font-mono text-xs uppercase text-muted-foreground">{entries.length} total</p>
               </div>

               {entries.length > 0 ? (
                  <ul class="divide-y divide-border">
                     {entries.map((entry) => (
                        <li>
                           <a href={`/${section.slugSingular}/${entry.slug}`} class="group block py-5 transition hover:bg-muted/50">
                              <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                                 <div class="flex items-center gap-2">
                                    {section.slugSingular === "concept" && entry.conceptKind ? (
                                       <ConceptKindIcon conceptKind={entry.conceptKind} client:only="react" />
                                    ) : null}
                                    <h3 class="font-serif text-2xl font-medium">{entry.title}</h3>
                                 </div>
                                 <span class="font-mono text-xs uppercase text-muted-foreground sm:pt-2">
                                    /{section.slugSingular}/{entry.slug}
                                 </span>
                              </div>
                              <p class="mt-2 max-w-3xl text-sm leading-6 text-muted-foreground">{entry.description}</p>
                           </a>
                        </li>
                     ))}
                  </ul>
               ) : (
                  <p class="py-6 text-sm leading-6 text-muted-foreground">No entries have been published in this section yet.</p>
               )}
            </section>
         </section>
      ) : (
         <NotFoundPage path={Astro.url.pathname} />
      )
   }
</HeaderLayout>
