---
import HeaderLayout from "@/layouts/HeaderLayout.astro";
import BreadcrumbTrail from "@/components/BreadcrumbTrail.astro";
import NotFoundPage from "@/components/NotFoundPage.astro";
import SectionIcon, { ConceptKindIcon } from "@/components/icons/section-icon";
import { getFormationIntersectionSummaryBySlug, listEntrySummariesByFormationIntersectionSlug } from "@/lib/exp3";

export const prerender = false;

const { slug } = Astro.params;

const section = slug ? await getFormationIntersectionSummaryBySlug(slug) : null;

if (!section) {
   Astro.response.status = 404;
}

const entries = slug && section ? await listEntrySummariesByFormationIntersectionSlug(slug) : [];
---

<HeaderLayout
   title={section ? `${section.name} — Exploriter` : "Page Not Found — Exploriter"}
   description={section?.description ?? "The requested page could not be found."}
>
   {
      section ? (
         <section class="mx-auto max-w-6xl px-4 pb-20">
            <BreadcrumbTrail items={[{ label: section.name }]} />

            <div class="mt-8">
               <div class="flex items-center gap-4">
                  <h1 class="min-w-0 shrink-0 -ml-0.5 font-serif text-5xl leading-tight">{section.name}</h1>
                  <span class="hidden h-px min-w-0 flex-1 border-t border-dashed border-border sm:block" aria-hidden="true" />
                  <SectionIcon slug={section.slug} label={section.nameSingular} className="hidden size-8 sm:block" client:only="react" />
               </div>
               <p class="mt-5 text-base leading-7 text-muted-foreground">{section.description}</p>
            </div>

            <section class="mt-12">
               <div class="flex items-end justify-between gap-4 border-b border-border pb-3">
                  <h2 class="font-mono text-xs uppercase text-muted-foreground">Entries</h2>
                  <p class="font-mono text-xs uppercase text-muted-foreground">{entries.length} total</p>
               </div>

               {entries.length > 0 ? (
                  <ul class="divide-y divide-border">
                     {entries.map((entry) => (
                        <li>
                           <a
                              href={`/${section.slugSingular}/${entry.slug}`}
                              class="group -mx-3 block rounded-md px-3 py-5 transition hover:bg-muted/50 sm:-mx-4 sm:px-4"
                           >
                              <div class="flex items-center">
                                 {section.slugSingular === "concept" && entry.conceptKind ? (
                                    <ConceptKindIcon
                                       className="size-5 hidden sm:block mr-2"
                                       conceptKind={entry.conceptKind}
                                       weight="regular"
                                       client:only="react"
                                    />
                                 ) : null}
                                 <h3 class="font-serif text-xl group-hover:underline group-hover:decoration-1 group-hover:underline-offset-2">
                                    {entry.title}
                                 </h3>
                              </div>
                              <p class="mt-2 max-w-3xl text-sm leading-6 text-muted-foreground">{entry.description}</p>
                           </a>
                        </li>
                     ))}
                  </ul>
               ) : (
                  <p class="py-6 text-sm leading-6 text-muted-foreground">No entries have been published in this section yet.</p>
               )}
            </section>
         </section>
      ) : (
         <NotFoundPage path={Astro.url.pathname} />
      )
   }
</HeaderLayout>
